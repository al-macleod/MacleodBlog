# =============================================================================
# BuzzForge Backend – Environment Configuration
# =============================================================================
# Copy this file to .env and fill in every value before starting the server.
# NEVER commit your .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Port the Express server listens on.
PORT=5000

# Deployment environment. Affects cookie security, CSP upgrade-insecure-requests,
# and whether password-reset tokens are exposed in API responses.
# Values: development | production | test
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Full MongoDB connection URI.
# Production example: mongodb+srv://<user>:<password>@cluster.mongodb.net/buzzforge
MONGODB_URI=mongodb://localhost:27017/buzzforge

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Comma-separated list of allowed origins for cross-origin requests.
# Must match the exact origin (protocol + host + port) of your frontend(s).
# Example (multiple): http://localhost:3000,https://app.buzzforge.com
CORS_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Authentication – Admin
# -----------------------------------------------------------------------------

# Admin console credentials. Use a strong, unique password in production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Name of the cookie that stores the admin JWT.
ADMIN_COOKIE_NAME=buzzforge_admin_token

# SameSite policy for the admin cookie.
# Values: strict | lax | none  (use "none" only when cross-site; requires Secure=true)
ADMIN_COOKIE_SAME_SITE=lax

# Set to "true" when served over HTTPS (required in production).
ADMIN_COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# Authentication – User
# -----------------------------------------------------------------------------

# Name of the cookie that stores the user JWT.
USER_COOKIE_NAME=buzzforge_user_token

# SameSite policy for the user cookie.
USER_COOKIE_SAME_SITE=lax

# Set to "true" when served over HTTPS (required in production).
USER_COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------

# Secret used to sign and verify all JWTs (admin + user).
# Generate a strong value: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# KEEP THIS SECRET – rotating it invalidates all existing sessions.
JWT_SECRET=replace-with-a-64-char-random-hex-secret

# -----------------------------------------------------------------------------
# OAuth – Google Sign-In
# -----------------------------------------------------------------------------

# OAuth 2.0 client ID from Google Cloud Console.
# Required for Google Sign-In to work; leave empty to disable the feature.
GOOGLE_CLIENT_ID=your-google-oauth-client-id

# -----------------------------------------------------------------------------
# Password Reset
# -----------------------------------------------------------------------------

# How long (in minutes) a password-reset token remains valid.
# Default: 30 minutes.
RESET_PASSWORD_TOKEN_TTL_MINUTES=30

# -----------------------------------------------------------------------------
# File Uploads
# -----------------------------------------------------------------------------

# Directory where uploaded media files are stored (relative to backend root).
UPLOAD_DIR=./uploads

# Maximum upload size in bytes. Default: 10 MB.
MAX_FILE_SIZE=10485760

# -----------------------------------------------------------------------------
# Logging (Winston + daily-rotate-file)
# -----------------------------------------------------------------------------

# Directory where log files are written (relative to backend root).
LOG_DIR=./logs

# Minimum log level to record.
# Values (least → most verbose): error | warn | info | http | verbose | debug | silly
# Defaults to "info" in production and "debug" in development.
LOG_LEVEL=debug

# Maximum size of a single log file before it is rotated (e.g. 20m, 1g).
LOG_MAX_SIZE=20m

# How long to keep rotated log files. Use "Nd" for N days or "N" for N files.
LOG_MAX_FILES=14d
