PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/buzzforge
CORS_ORIGIN=http://localhost:3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_COOKIE_NAME=buzzforge_admin_token
ADMIN_COOKIE_SAME_SITE=lax
ADMIN_COOKIE_SECURE=false
USER_COOKIE_NAME=buzzforge_user_token
USER_REFRESH_COOKIE_NAME=buzzforge_refresh_token
USER_COOKIE_SAME_SITE=lax
USER_COOKIE_SECURE=false
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/users/auth/google/callback
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/users/auth/github/callback
RESET_PASSWORD_TOKEN_TTL_MINUTES=30
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM_NAME=BuzzForge
EMAIL_FROM_ADDRESS=noreply@example.com
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
